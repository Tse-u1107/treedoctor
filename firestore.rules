rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Public, minimal aggregate for landing page map colors.
    match /publicStats/provinceCoverage {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2028, 12, 31);
    }
  }
}